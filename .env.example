# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Prisma / SQLite database location. For Postgres use e.g.
#   postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./dev.db"

# Password required to log in to the admin dashboard at /admin/messages.
ADMIN_PASSWORD="set-a-strong-password"

# Secret used to sign the admin session cookie. Generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET="generate-a-32-char-random-string"
